# OpenSSL configuration for the RSA subordinate CA.
# This CA signs RSA leaf certificates and enforces pathlen:0.

[ ca ]
default_ca = CA_default

[ CA_default ]
dir               = ./Sub_RSA_CA_1_BPA
certs             = $dir/certs
new_certs_dir     = $dir/newcerts
database          = $dir/db/index.txt
serial            = $dir/db/serial
crlnumber         = $dir/db/crlnumber
crl               = $dir/db/crl.pem
certificate       = $dir/certs/Sub_RSA_CA_1_BPA.crt
private_key       = $dir/private/Sub_RSA_CA_1_BPA.key.pem
default_md        = sha256
default_days      = 3650
policy            = policy_loose
email_in_dn       = no
unique_subject    = no
copy_extensions   = none
preserve          = no

[ policy_loose ]
countryName             = optional
stateOrProvinceName     = optional
localityName            = optional
organizationName        = optional
organizationalUnitName   = optional
commonName              = supplied
emailAddress            = optional

[ req ]
default_bits        = 3072
default_md          = sha256
prompt              = no
distinguished_name   = dn

[ dn ]
C  = FR
O  = TP Crypto Agents
OU = PKI OpenSSL
CN = Sub_RSA_CA_1_BPA

[ v3_sub_ca ]
basicConstraints      = critical, CA:TRUE, pathlen:0
keyUsage              = critical, keyCertSign, cRLSign
subjectKeyIdentifier  = hash
authorityKeyIdentifier = keyid:always,issuer

[ v3_leaf ]
basicConstraints      = critical, CA:FALSE
keyUsage              = critical, digitalSignature, keyEncipherment
extendedKeyUsage      = serverAuth, clientAuth
subjectKeyIdentifier  = hash
authorityKeyIdentifier = keyid,issuer
subjectAltName        = @leaf_san

[ leaf_san ]
DNS.1 = leaf-rsa-1.bpa.local
DNS.2 = leaf-rsa-1
